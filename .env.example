# ==================================================
# Nexus Learning Platform - Environment Variables
# ==================================================
# Copy this file to .env.local and fill in your values

# ==================== DATABASE ====================
DATABASE_URL="postgresql://nexus:nexus_dev_password@localhost:5432/nexus_learning"

# ==================== REDIS ====================
REDIS_URL="redis://localhost:6379"

# ==================== MEILISEARCH ====================
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_KEY="nexus_search_dev_key"

# ==================== CLERK AUTH ====================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_key_here"
CLERK_SECRET_KEY="sk_test_your_key_here"
CLERK_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/student/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ==================== API ====================
NEXT_PUBLIC_API_URL="http://localhost:4000/v1"
FRONTEND_URL="http://localhost:3000"
PORT=4000

# ==================== AI PROVIDERS ====================
OPENAI_API_KEY="sk-your-openai-key-here"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key-here"

# ==================== STRIPE ====================
STRIPE_SECRET_KEY="sk_test_your_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_key"

# ==================== STORAGE ====================
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_BUCKET_NAME="nexus-assets"

# ==================== MONITORING ====================
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ==================== APP ====================
NODE_ENV="development"
